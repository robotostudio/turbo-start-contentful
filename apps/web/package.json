{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "check-types": "tsc --noEmit",
    "typegen": ". ./.env && cf-content-types-generator -s \"$CONTENTFUL_SPACE_ID\" -t \"$CONTENTFUL_MANAGEMENT_TOKEN\" -o ./src/lib/contentful/types --v10 && eslint --fix ./src/lib/contentful/types && prettier --write ./src/lib/contentful/types",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "node --env-file=.env scripts/seed-contentful.mjs"
  },
  "dependencies": {
    "@contentful/live-preview": "^4.10.5",
    "@contentful/rich-text-react-renderer": "^16.2.1",
    "@contentful/rich-text-types": "^17.2.7",
    "@contentful/vercel-nextjs-toolkit": "^1.6.0",
    "@next/env": "^16.2.6",
    "@workspace/ui": "workspace:*",
    "cf-content-types-generator": "^3.0.1",
    "contentful": "^11.12.2",
    "lucide-react": "1.16.0",
    "motion": "^12.39.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "schema-dts": "^2.0.0",
    "server-only": "^0.0.1",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^10.4.0",
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^16.2.6",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-turbo": "^2.9.14",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.59.4",
    "babel-plugin-react-compiler": "19.0.0-beta-e993439-20250328",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^3.2.2",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "contentful-management": "^11.59.4",
    "jsdom": "^26.1.0",
    "postcss": "^8",
    "tailwindcss": "^4.1",
    "vitest": "^3.2.2"
  },
  "browserslist": [
    "defaults and supports es6-module",
    "maintained node versions"
  ]
}
